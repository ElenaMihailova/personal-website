{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\"",
    "check": "prettier --check . && eslint . && stylelint \"src/**/*.{css,scss}\"",
